{
  "schemaVersion": 1,
  "id": "wurst-meteor-addon",
  "version": "${version}",
  "name": "Wurstmeteor Addon",
  "description": "Wurst-inspired combat, farm, render, and chunk modules for Meteor Client.",
  "authors": [
    "nljent"
  ],
  "contact": {
    "sources": "https://github.com/njlent/wurst-for-meteor-client-addon"
  },
  "license": "GPL-3.0-only",
  "icon": "assets/wurstmeteor/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "de.njlent.wurstmeteor.WurstMeteorAddon"
    ]
  },
  "mixins": [
    "wurst-meteor.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": [
      "${mc_version}"
    ],
    "fabricloader": ">=0.18.0",
    "meteor-client": "*",
    "fabric-api": "*"
  }
}
